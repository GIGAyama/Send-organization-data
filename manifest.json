{
  "manifest_version": 3,
  "name": "Google Data Transfer",
  "version": "1.0",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
