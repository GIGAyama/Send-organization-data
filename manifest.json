{
  "manifest_version": 3,
  "name": "Google Data Transfer",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "notifications",
    "contextMenus",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://drive.google.com/*",
    "https://script.google.com/*",
    "https://*.googleusercontent.com/*"
  ],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
